#!/usr/bin/env sh
set -eu

ROOT_DIR=$(CDPATH= cd -- "$(dirname -- "$0")/../.." && pwd)
ZK_DIR="$ROOT_DIR/zk/eligibility"
BUILD_DIR="$ZK_DIR/build"

mkdir -p "$BUILD_DIR"

circom "$ZK_DIR/eligibility.circom" --prime bls12381 --r1cs --wasm --sym -o "$BUILD_DIR"

snarkjs powersoftau new bls12381 8 "$BUILD_DIR/pot12_0000.ptau"
snarkjs powersoftau contribute "$BUILD_DIR/pot12_0000.ptau" "$BUILD_DIR/pot12_0001.ptau" --name="clawloan-demo" -e="clawloan-demo-entropy"
snarkjs powersoftau prepare phase2 "$BUILD_DIR/pot12_0001.ptau" "$BUILD_DIR/pot12_final.ptau"

snarkjs groth16 setup "$BUILD_DIR/eligibility.r1cs" "$BUILD_DIR/pot12_final.ptau" "$BUILD_DIR/eligibility_0000.zkey"
snarkjs zkey contribute "$BUILD_DIR/eligibility_0000.zkey" "$BUILD_DIR/eligibility_final.zkey" --name="clawloan-demo-zkey" -e="clawloan-demo-zkey-entropy"
snarkjs zkey export verificationkey "$BUILD_DIR/eligibility_final.zkey" "$BUILD_DIR/verification_key.json"

snarkjs groth16 fullprove "$ZK_DIR/input.json" "$BUILD_DIR/eligibility_js/eligibility.wasm" "$BUILD_DIR/eligibility_final.zkey" "$BUILD_DIR/proof.json" "$BUILD_DIR/public.json"
snarkjs groth16 verify "$BUILD_DIR/verification_key.json" "$BUILD_DIR/public.json" "$BUILD_DIR/proof.json"

node "$ROOT_DIR/scripts/clawloan/write-proof-receipt.mjs" \
  "$BUILD_DIR/proof.json" \
  "$BUILD_DIR/public.json" \
  "$BUILD_DIR/verification_key.json" \
  "$BUILD_DIR/proof-receipt.json"
